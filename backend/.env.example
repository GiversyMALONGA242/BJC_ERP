# ============================================================
# IMPRIMERIE BJC — Configuration
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=VOTRE_MOT_DE_PASSE_MYSQL
DB_NAME=imprimerie_bjc_v2

# JWT (changez cette valeur — clé secrète de sécurité)
JWT_SECRET=BJC_2026_Pointe_Noire_Congo_SECRET_CHANGEZ_MOI

# Serveur
PORT=3001
NODE_ENV=production

# Dossier d'archivage sur le serveur (créé automatiquement)
# Laissez vide pour utiliser le dossier par défaut (Documents/BJC_Archives)
ARCHIVES_DIR=

# URL frontend (laisser vide en production avec PM2+build)
FRONTEND_URL=
